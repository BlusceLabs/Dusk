# ─────────────────────────────────────────────
#  DUSK — Environment Variables Reference
#  Copy this file to .env and fill in values.
#  EXPO_PUBLIC_* vars are exposed to the mobile client.
# ─────────────────────────────────────────────

# ── Firebase (required by both mobile app and API server) ──
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=

# ── API Server URL (set to your Replit dev domain or deployment URL) ──
EXPO_PUBLIC_DOMAIN=https://your-replit-dev-domain.replit.dev

# ── Expo Push Notifications ──
EXPO_PUBLIC_PROJECT_ID=your-expo-project-id   # from expo.dev dashboard

# ── Neon PostgreSQL ──
NEON_DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── Upstash Redis ──
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=

# ── RabbitMQ / CloudAMQP ──
RABBITMQ_URL=amqps://user:password@your-instance.cloudamqp.com/vhost

# ── Cloudflare R2 (media storage) ──
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=dusk-media
R2_PUBLIC_URL=https://your-bucket.your-account.r2.cloudflarestorage.com

# ── Resend (transactional email) ──
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ── PayPal (Premium subscriptions) ──
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# ── DataStax Astra (Cassandra — analytics / feed) ──
ASTRA_DB_API_ENDPOINT=https://your-db-id-region.apps.astra.datastax.com
ASTRA_DB_TOKEN=AstraCS:...

# ── API Server ──
SESSION_SECRET=change-this-to-a-long-random-string
API_ADMIN_TOKEN=change-this-to-a-long-random-string
NODE_ENV=development
LOG_LEVEL=info
