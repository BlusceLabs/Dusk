modules = ["nodejs-24", "java-graalvm22.3", "rust-stable", "python-3.11"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "services/feed: Scala"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "services/media: C++"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "services/realtime: Java"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "services/rate-limiter: Rust"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "services/ml: Python Django"

[[workflows.workflow]]
name = "services/feed: Scala"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=3002 bash artifacts/feed-service/start.sh"
waitForPort = 3002

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "services/media: C++"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=3003 bash artifacts/media-service/start.sh"
waitForPort = 3003

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "services/realtime: Java"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=3001 bash artifacts/realtime-service/start.sh"
waitForPort = 3001

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "services/rate-limiter: Rust"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=3000 bash artifacts/rate-limiter/start.sh"
waitForPort = 3000

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "services/ml: Python Django"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=8000 bash artifacts/ml-service/start.sh"
waitForPort = 8000

[workflows.workflow.metadata]
outputType = "console"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["resend:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 3000
externalPort = 5173

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 3002
externalPort = 5000

[[ports]]
localPort = 3003
externalPort = 4200

[[ports]]
localPort = 8000
externalPort = 8000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 8082
externalPort = 3002

[[ports]]
localPort = 22400
externalPort = 3000

[[ports]]
localPort = 22401
externalPort = 3003

