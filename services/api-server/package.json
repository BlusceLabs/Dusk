    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "amqplib": "^1.0.3",
    "cassandra-driver": "^4.8.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "drizzle-orm": "catalog:",
    "express": "^5",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "jwks-rsa": "^4.0.1",
    "pino": "^9",
